# Backend Environment Variables – Example
# Copy to .env and fill in actual values. DO NOT commit .env.

# ── Database ──────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRATION=

# ── Admin Seed (created once on first startup) ────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
