# Backend Environment Variables
# Copy this file to .env and fill in actual values
# Load before running: export $(cat .env | xargs) && mvn spring-boot:run

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lara_dashboard
DB_USER=root
DB_PASSWORD=Pass@32997

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8080

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=LaRaCareSecretKey2024VeryLongSecretForHMACSHA256SigningKey
JWT_EXPIRATION=86400000

# ── Admin Seed (created once on first startup) ────────────────
ADMIN_EMAIL=admin@lara.ai
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=LaRa System Admin
